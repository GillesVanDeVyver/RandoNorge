diff --git a/worker/winter.js b/worker/winter.js
new file mode 100644
index 0000000..bc23634
--- /dev/null
+++ b/worker/winter.js
@@ -0,0 +1,155 @@
+// Winter-imagery tile endpoint for the "winter" map overlay (see
+// worker/index.js).
+//
+//   GET /winter-tiles/{z}/{x}/{y}.jpg  →  Sentinel-2 Q1 cloudless mosaic tile
+//
+// The imagery is the Copernicus Data Space Ecosystem (CDSE) "Sentinel-2
+// quarterly cloudless mosaic" for Q1 (January–March) — true winter satellite
+// imagery with snow on the ground, the closest open replacement for FATMAP's
+// winter imagery. 10 m/px, so tiles are generated to z14 and the client
+// overzooms beyond that.
+//
+// License: CC BY 4.0 — "Contains modified Copernicus Sentinel data [year]
+// processed by Sentinel Hub". The credit is rendered by <MapAttribution/>
+// whenever the winter overlay is active; keep the year there in sync with
+// WINTER_TIME below.
+//
+// Serving order:
+//   1. R2 (binding TERRAIN, key winter/{version}/{z}/{x}/{y}.jpg). A given
+//      quarter's mosaic never changes once published, so tiles are written
+//      back on first fetch and served from R2 forever after — each tile
+//      costs CDSE quota exactly once, ever.
+//   2. CDSE Sentinel Hub OGC WMTS (sh.dataspace.copernicus.eu). Requires a
+//      configured OGC instance; see SETUP below. Free tier: 50 000 OGC
+//      requests/month — comfortably enough for cache misses only.
+//
+// SETUP (one-time, free CDSE account):
+//   1. Register at https://dataspace.copernicus.eu and open the Sentinel Hub
+//      dashboard (Copernicus users get the free-tier quota automatically).
+//   2. Create a "Configuration" (OGC instance) with a layer named WINTER on
+//      the Sentinel-2 quarterly mosaics collection
+//      (byoc-5460de54-082e-473a-b6ea-d5cbe3c17cca), TRUE_COLOR evalscript.
+//   3. Store the instance id as a Worker secret:
+//        npx wrangler secret put CDSE_WINTER_INSTANCE_ID
+//   Until the secret exists the endpoint returns 503 and the frontend layer
+//   simply renders no tiles — everything else keeps working.
+
+// Which quarterly mosaic to serve: any date inside the target quarter.
+// Q1 of the most recent fully published year. Bump once a year when the new
+// Q1 mosaic lands (and bump WINTER_VERSION with it to roll the caches).
+const WINTER_TIME = '2026-02-01';
+
+// Folded into R2 keys and the edge cache key; bump together with
+// WINTER_TIME (or after changing the OGC layer/evalscript) so previously
+// cached tiles are invalidated in one go.
+const WINTER_VERSION = 'q1-2026b'; // b: snow-preserving tone-map evalscript
+
+// Layer name of the OGC instance configuration (step 2 above).
+const WINTER_LAYER = 'WINTER';
+
+// Sentinel-2 mosaics are 10 m/px — z14 (~6 m/px at 60°N) already oversamples
+// them slightly, so there is no detail beyond it. Leaflet/MapLibre upscale
+// client-side past this.
+const MAX_ZOOM = 14;
+
+// The mosaic collection rejects requests coarser than 1600 m/px, rendering a
+// red error-text tile instead of imagery. WebMercator 256px tiles are
+// 156543/2^z m/px: z6 ≈ 2446 (rejected), z7 ≈ 1223 (ok) — so z7 is the
+// lowest level we ever ask upstream for. The clients scale z7 tiles for
+// lower zooms (Leaflet minNativeZoom / MapLibre source minzoom).
+const MIN_ZOOM = 7;
+
+const TILE_RE = /^\/winter-tiles\/(\d{1,2})\/(\d+)\/(\d+)\.jpg$/;
+
+/** Handle GET /winter-tiles/{z}/{x}/{y}.jpg. Returns null when the path
+ *  doesn't match, so the caller can fall through to other routes. */
+export async function handleWinterTile(request, env, ctx) {
+  const url = new URL(request.url);
+  const m = TILE_RE.exec(url.pathname);
+  if (!m) return null;
+
+  if (request.method !== 'GET') {
+    return new Response('Method not allowed', { status: 405 });
+  }
+
+  const z = Number(m[1]);
+  const x = Number(m[2]);
+  const y = Number(m[3]);
+  const n = 2 ** z;
+  if (z > MAX_ZOOM || z < MIN_ZOOM || x >= n || y >= n) {
+    return new Response('Tile out of range', { status: 404 });
+  }
+
+  // Edge cache lookup (version folded into the key, like terrain.js).
+  const cache = caches.default;
+  const cacheKey = new Request(
+    `${url.origin}${url.pathname}?v=${WINTER_VERSION}`,
+  );
+  const hit = await cache.match(cacheKey);
+  if (hit) return hit;
+
+  const r2Key = `winter/${WINTER_VERSION}/${z}/${x}/${y}.jpg`;
+
+  // 1) R2 write-through cache: any tile ever fetched lives here permanently.
+  if (env.TERRAIN) {
+    const obj = await env.TERRAIN.get(r2Key);
+    if (obj) {
+      const res = tileResponse(obj.body);
+      ctx.waitUntil(cache.put(cacheKey, res.clone()));
+      return res;
+    }
+  }
+
+  // 2) CDSE Sentinel Hub WMTS. PopularWebMercator256 matches the standard
+  //    z/x/y WebMercator pyramid, so indices map 1:1.
+  const instanceId = env.CDSE_WINTER_INSTANCE_ID;
+  if (!instanceId) {
+    return new Response('Winter imagery not configured', {
+      status: 503,
+      headers: { 'Cache-Control': 'no-store' },
+    });
+  }
+  const upstreamUrl =
+    `https://sh.dataspace.copernicus.eu/ogc/wmts/${instanceId}` +
+    `?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0` +
+    `&LAYER=${WINTER_LAYER}&STYLE=default` +
+    `&TILEMATRIXSET=PopularWebMercator256` +
+    `&TILEMATRIX=${z}&TILEROW=${y}&TILECOL=${x}` +
+    // SHOWLOGO=false drops the Copernicus watermark baked into each tile;
+    // the required CC BY credit is rendered by <MapAttribution/> instead.
+    `&FORMAT=image/jpeg&TIME=${WINTER_TIME}&SHOWLOGO=false`;
+  const upstream = await fetch(upstreamUrl);
+  if (!upstream.ok) {
+    // Pass the status through but never cache errors (quota exhaustion or
+    // transient CDSE errors must not stick).
+    return new Response(upstream.body, {
+      status: upstream.status,
+      headers: { 'Cache-Control': 'no-store' },
+    });
+  }
+
+  // Buffer the tile so it can go to the browser, the edge cache, and R2 at
+  // once. Tiles are 256px JPEGs (tens of kB) — fine to hold in memory.
+  const bytes = await upstream.arrayBuffer();
+  if (env.TERRAIN) {
+    ctx.waitUntil(
+      env.TERRAIN.put(r2Key, bytes, {
+        httpMetadata: { contentType: 'image/jpeg' },
+      }),
+    );
+  }
+  const res = tileResponse(bytes);
+  ctx.waitUntil(cache.put(cacheKey, res.clone()));
+  return res;
+}
+
+function tileResponse(body) {
+  return new Response(body, {
+    headers: {
+      'Content-Type': 'image/jpeg',
+      // Immutable per version; WINTER_VERSION bumps handle the yearly roll.
+      'Cache-Control': 'public, max-age=31536000, immutable',
+      'X-Winter-Source': `sentinel2-q1-${WINTER_VERSION}`,
+    },
+  });
+}
